JWT_SECRET_KEY=changeThisSecretWithAVeryLongOneInOrderToMakeItWork

BACKEND_PORT=8080
BACKEND_PROFILE=prod

DB_HOST=postgres
DB_PORT=5432
DB_NAME=tennis_platform_db
DB_USER=postgres-tfm
DB_PASSWORD=alsoChangeThisSecret

DATASOURCE_URL=jdbc:postgresql://${DB_HOST}:5432/${DB_NAME}

# HTTPS reverse proxy. For local HTTPS use localhost. For a public demo use your DNS name.
PUBLIC_DOMAIN=demo.example.com
LOCAL_SERVER_NAME=localhost
HTTPS_HTTP_PORT=80
HTTPS_PORT=443

FRONTEND_PORT=4200
FRONTEND_ALLOWED_HOSTS=${LOCAL_SERVER_NAME},127.0.0.1
# Public URL used by the browser to call the backend. Do not use Docker-only hostnames like "backend" here.
FRONTEND_API_URL=http://localhost:${BACKEND_PORT}/api
# FRONTEND_API_URL=https://${LOCAL_SERVER_NAME}/api

# Business rule: true blocks login until the user confirms email; false creates users already verified.
EMAIL_CONFIRMATION_REQUIRED=false
# Transport switch: true sends real SMTP email; false logs the confirmation link when confirmation is required.
EMAIL_CONFIRMATION_ENABLED=false
# Sender shown in confirmation emails. For Gmail SMTP, use the same address as MAIL_USERNAME.
EMAIL_FROM=no-reply@tennis-platform.local
# Public frontend route used in confirmation links. Backend appends ?token=...
FRONTEND_CONFIRMATION_URL=http://localhost:4200/confirmar-email
# FRONTEND_CONFIRMATION_URL=https://${LOCAL_SERVER_NAME}/confirmar-email #Local NGINX

# Confirmation token lifetime in minutes.
EMAIL_CONFIRMATION_TOKEN_EXPIRATION_MINUTES=1440

# SMTP settings. Required only when EMAIL_CONFIRMATION_ENABLED=true.
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true # Auth required?
MAIL_SMTP_STARTTLS_ENABLE=true # Connection start in text plain and then get updated to use TLS (use true in prod)

# Local Docker adoption flag: lets Flyway create schema history on a non-empty DB previously initialized without Flyway.
FLYWAY_BASELINE_ON_MIGRATE=true
FLYWAY_BASELINE_VERSION=0

# Pro players CSV import. Disabled by default; enable it when the backend should load ranking CSVs.
PRO_PLAYERS_IMPORT_ENABLED=false
# Runs one import when the backend starts. Requires PRO_PLAYERS_IMPORT_ENABLED=true.
PRO_PLAYERS_IMPORT_RUN_ON_STARTUP=false
# Spring cron expression. Default: every Monday at 04:00.
PRO_PLAYERS_IMPORT_CRON="0 0 4 * * MON"
# JDBC batch size used during import.
PRO_PLAYERS_IMPORT_BATCH_SIZE=1000
# CSV locations. Defaults point to bundled files under backend/src/main/resources/db/seed.
# Use https://... for remote CSVs or file:/data/file.csv for mounted files in Docker/cloud.
PRO_PLAYERS_MALE_CSV_LOCATION=classpath:db/seed/pro_players_male.csv
PRO_PLAYERS_FEMALE_CSV_LOCATION=classpath:db/seed/pro_players_female.csv

# Google Places autocomplete settings. Keep the key server-side; frontend calls the backend proxy.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_PLACES_BASE_URL=https://places.googleapis.com

# ─── EC2 / Production Resource Limits ───────────────────────────────────────
# Applied via compose.override.ec2.yaml. Do NOT set these in this .env file;
# they live in the override so local dev is not affected.
#
# Production deploy command (EC2):
#   docker compose -f compose.yaml -f compose.https-local.yaml -f compose.override.ec2.yaml up -d --remove-orphans
#
# Setup swap on EC2 (run once as root):
#   sudo bash scripts/setup-ec2-swap.sh
#
# RAM budget for t3.small (2 GB):
#   postgres:  256 MB  (shared_buffers=64MB, max_connections=20)
#   backend:   640 MB  → JVM heap ≈ 480 MB (UseContainerSupport + MaxRAMPercentage=75)
#   frontend:  256 MB  → Node.js heap ≈ 192 MB
#   nginx:      64 MB
#
# To upgrade to t3.medium (4 GB), increase limits in compose.override.ec2.yaml:
#   postgres=512M, backend=1024M, frontend=512M, nginx=64M
